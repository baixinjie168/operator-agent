PROJECT_NAME=operator-agent
DEBUG=false
OPERATORS_DIR=operators
DATABASE_PATH=data/operator_agent.db
LOG_LEVEL=INFO

# LLM provider: "zai", "deepseek", "own-ai", or "qwen"
LLM_PROVIDER=zai

# Shared LLM settings
LLM_TEMPERATURE=0.7

# Z.AI configuration
ZAI_API_KEY=your-zai-api-key
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
# ZAI_MODEL=glm-5.1

# DeepSeek configuration
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# Own-AI 配置（OpenAI 兼容 API）
OWN_AI_API_KEY=sk-your-api-key-here
OWN_AI_BASE_URL=https://your-api-endpoint.com/v1
OWN_AI_MODEL=your-model-name

# Qwen 配置（DashScope OpenAI 兼容接口）
QWEN_API_KEY=your-qwen-api-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3.7-max