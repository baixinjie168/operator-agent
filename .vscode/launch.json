{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Operator Agent (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "agent.main:create_app",
                "--factory",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "envFile": "${workspaceFolder}/.env",
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "Operator Agent (FastAPI + Reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "agent.main:create_app",
                "--factory",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "env": {
                "PYTHONUNBUFFERED": "1"
            },
            "envFile": "${workspaceFolder}/.env",
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": false
        },
        {
            "name": "Pytest: Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v"
            ],
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": false
        },
        {
            "name": "Pytest: All Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v"
            ],
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": false
        }
    ]
}
