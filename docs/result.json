  "constraints_in_parameters": {
    "Atlas 推理系列产品": [
      {
        "expr_type": "type_dependency",
        "expr": "all(x.dtype != 'bfloat16' for x in [x1, x2, beta, gamma, biasOptional, yOut, xOut])",
        "relation_params": [
          "x1",
          "x2",
          "beta",
          "gamma",
          "biasOptional",
          "yOut",
          "xOut"
        ],
        "src_text": "参数`x1`、`x2`、`beta`、`gamma`、`biasOptional`、`yOut`、`xOut`的数据类型不支持BFLOAT16。"
      },
      {
        "expr_type": "shape_equality",
        "expr": "x2.shape == x1.shape",
        "relation_params": [
          "x2",
          "x1"
        ],
        "src_text": "shape和`x1`保持一致。"
      },
      {
        "expr_type": "shape_dependency",
        "expr": "(meanOut.ndim == x1.ndim) and all(meanOut.shape[i] == x1.shape[i] for i in range(x1.ndim - gamma.ndim)) and all(meanOut.shape[i] == 1 for i in range(x1.ndim - gamma.ndim, x1.ndim))",
        "relation_params": [
          "meanOut",
          "x1",
          "gamma"
        ],
        "src_text": "shape需要与`x1`满足broadcast关系（前几维的维度和`x1`前几维的维度相同，后面的维度为1，总维度与`x1`维度相同，前几维指`x1`的维度减去gamma的维度，表示不需要norm的维度）。"
      }
    ],
    "Atlas A2 训练系列产品/Atlas A2 推理系列产品、Atlas A3 训练系列产品/Atlas A3 推理系列产品": [
